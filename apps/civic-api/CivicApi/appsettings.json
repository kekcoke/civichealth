{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CivicDb": "Host=${CIVIC_DB_HOST:-localhost};Port=${CIVIC_DB_PORT:-5432};Database=${CIVIC_DB_NAME:-civic_public};Username=${CIVIC_DB_USER:-postgres};Password=${CIVIC_DB_PASSWORD:-}"
  }
}
